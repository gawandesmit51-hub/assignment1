   "source": [
    "#Odd or Even:\n",
    "#Check whether a given number is even or odd"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "7357893e-cbc8-4a8d-8aef-53f829314d9e",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter the number 1022\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The given number is Even\n"
     ]
    }
   ],
   "source": [
    "num=int(input(\"Enter the number\"))\n",
    "if num % 2 == 0:\n",
    "    print(\"The given number is Even\")\n",
    "else:\n",
    "    print(\"The given number is odd\")"
   ]
  },
