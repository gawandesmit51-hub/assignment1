   "source": [
    "#Sum of N Natural Numbers:\n",
    "#Write a program to calculate the sum of the first N natural numbers."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "93f81fcb-c053-478d-90b3-2800122f9573",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a natural no. 5\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "15 is the sum\n"
     ]
    }
   ],
   "source": [
    "n=int(input(\"Enter a natural no.\"))\n",
    "total=0\n",
    "for i in range(1,n+1):\n",
    "    total=total+i\n",
    "print(total,\"is the sum\")   "
   ]
  },
