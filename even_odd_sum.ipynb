   "source": [
    "#Sum of Odd and Even Numbers:\n",
    "#Take a list of numbers and find the sum of odd and even numbers separately"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "id": "4fd000bd-38cf-4201-967e-817cfd23461b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "even sums 174\n",
      "odd sums 265\n"
     ]
    }
   ],
   "source": [
    "l=[39,39,27,32,66,93,76,67]\n",
    "even_sum=0\n",
    "odd_sum=0\n",
    "for i in l:\n",
    "    if i % 2 ==0:\n",
    "        even_sum+=i\n",
    "    else:\n",
    "        odd_sum+=i\n",
    "print(\"even sums\",even_sum)\n",
    "print(\"odd sums\",odd_sum)\n",
    "        "
   ]
  },
